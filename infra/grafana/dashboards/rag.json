{
  "uid": "reglens-rag",
  "title": "RegLens — RAG Quality & Cost",
  "tags": ["reglens"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Chat outcomes",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(reglens_chat_requests_total[15m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Answer cache hit ratio (1h)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(reglens_answer_cache_events_total{result=\"hit\"}[1h])) / clamp_min(sum(increase(reglens_answer_cache_events_total[1h])), 1)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "LLM spend (24h)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(reglens_llm_cost_usd_total[24h]))" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token throughput",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (kind) (rate(reglens_llm_tokens_total[15m])) * 60",
          "legendFormat": "{{kind}} tokens/min"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Retrieval top score (p50 / p95)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(reglens_retrieval_top_score_bucket[30m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(reglens_retrieval_top_score_bucket[30m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Chat latency p95",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(reglens_chat_duration_seconds_bucket[15m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Assessments by outcome (1h)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(reglens_assessment_runs_total[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Avg cost / assessment (24h)",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(increase(reglens_assessment_cost_usd_sum[24h])) / clamp_min(sum(increase(reglens_assessment_cost_usd_count[24h])), 1)"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Assessments completed (24h)",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(reglens_assessment_runs_total[24h]))"
        }
      ]
    }
  ]
}
