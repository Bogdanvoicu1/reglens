# Copy to .env. Values come from your Supabase project: Project Settings → API.
# Both are safe to ship to the browser (the publishable/anon key is designed for
# client use). The service_role key must NEVER go here.
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>
