# Copy to .env and fill in. All variables are prefixed REGLENS_.

# OpenRouter (default) — or any OpenAI-compatible provider
REGLENS_LLM_API_KEY=sk-or-v1-...
REGLENS_LLM_BASE_URL=https://openrouter.ai/api/v1
REGLENS_EMBEDDING_MODEL=openai/text-embedding-3-small
REGLENS_GENERATION_MODEL=openai/gpt-4o-mini

REGLENS_DATABASE_URL=postgresql+asyncpg://reglens:reglens@localhost:5432/reglens
REGLENS_REDIS_URL=redis://localhost:6379/0

# Auth: Supabase JWKS endpoint for your project. Tokens are verified locally
# against it (no per-request call to Supabase). Find <ref> in your Supabase
# project URL. The SPA's matching VITE_SUPABASE_* vars live in frontend/.env.
REGLENS_SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
REGLENS_SUPABASE_ISSUER=https://<ref>.supabase.co/auth/v1

# Optional LLM tracing (Langfuse Cloud or self-hosted); off when unset
# REGLENS_LANGFUSE_PUBLIC_KEY=pk-lf-...
# REGLENS_LANGFUSE_SECRET_KEY=sk-lf-...
# REGLENS_LANGFUSE_HOST=https://cloud.langfuse.com

# Cost & privacy controls
REGLENS_GENERATION_MAX_TOKENS=1024
REGLENS_LOG_QUESTION_TEXT=false   # true logs/traces plaintext questions (dev only)
